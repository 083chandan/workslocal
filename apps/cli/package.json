{
  "name": "workslocal",
  "version": "0.1.0",
  "description": "Expose localhost to the internet - free, open-source tunneling tool",
  "type": "module",
  "bin": {
    "workslocal": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "author": "Chandan <083.chandan@gmail.com>",
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ora": "^9.3.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@workslocal/client": "workspace:*",
    "@workslocal/shared": "workspace:*",
    "@types/node": "^20.x"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "tunnel",
    "localhost",
    "https",
    "ngrok",
    "webhook",
    "catch",
    "inspector",
    "developer-tools",
    "workslocal"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/workslocal/workslocal.git"
  },
  "homepage": "https://workslocal.dev",
  "bugs": {
    "url": "https://github.com/workslocal/workslocal/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
